# ====================================================================
# Lead Radar - Environment Variables
# Diese Datei nach .env.local kopieren und Werte eintragen.
# .env.local wird NICHT committet (siehe .gitignore).
# Auf Vercel: dieselben Variablen unter Project Settings > Environment Variables anlegen.
# ====================================================================

# Scan-Datenquelle ist OpenStreetMap / Overpass: KEIN Key, KEIN Billing noetig.

# Optional: Google Maps Platform fuer Standort-Foto (Street View / Place-Foto)
# + Telefon/Adresse/Oeffnungszeiten im Lead-Detail. Wird serverseitig genutzt
# (Key bleibt geheim). OHNE diesen Key faellt der Drawer sauber auf Website-Bild
# bzw. Satellit + Ein-Klick-Links zurueck.
# Einrichtung: Google-Cloud-Projekt -> Billing aktivieren -> diese APIs aktivieren:
#   "Places API (New)" und "Street View Static API" -> API-Key erstellen.
GOOGLE_MAPS_API_KEY=

# Notion interner Integration-Token (beginnt mit "ntn_" oder "secret_").
NOTION_API_KEY=

# ID der Notion-Datenbank, in der die Leads liegen (32-stellige Hex-ID aus der DB-URL).
NOTION_LEADS_DATABASE_ID=

# Optional: Anthropic API Key fuer den KI-Outreach-Modus.
# Ohne diesen Key laeuft der Template-Modus (regelbasierte Vorlagen).
ANTHROPIC_API_KEY=
